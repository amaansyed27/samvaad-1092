# ──────────────────────────────────────────────────────────────────────────────
# SAMVAAD 1092 — Environment Configuration
# Copy this file to .env and fill in your API keys.
# IMPORTANT: NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Providers ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Provider Models ──────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3-flash
GROQ_MODEL=llama-3.3-70b-versatile
DEEPSEEK_MODEL=deepseek/deepseek-chat-v3

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Acoustic Guardian ───────────────────────────────────────────────────────
DISTRESS_THRESHOLD=0.85
WAV2VEC2_MODEL=facebook/wav2vec2-base

# ── PII Scrubber ────────────────────────────────────────────────────────────
PII_NER_MODEL=ai4bharat/IndicNER

# ── Dashboard ───────────────────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:8000/ws/call
