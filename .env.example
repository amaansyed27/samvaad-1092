# ──────────────────────────────────────────────────────────────────────────────
# SAMVAAD 1092 — Environment Configuration
# Copy this file to .env and fill in your API keys.
# IMPORTANT: NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── LLM Providers ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Provider Models ──────────────────────────────────────────────────────────
GEMINI_MODEL=gemini-3-flash
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Sarvam AI (Indian DPI — STT + TTS) ──────────────────────────────────────
SARVAM_API_KEY=your_sarvam_api_key_here
SARVAM_STT_MODEL=saaras:v3
SARVAM_STT_MODE=transcribe
SARVAM_TTS_MODEL=bulbul:v3
SARVAM_TTS_SPEAKER=priya
SARVAM_TTS_LANGUAGE=kn-IN
SARVAM_TTS_PACE=1.12
SARVAM_TTS_TEMPERATURE=0.25
SARVAM_TTS_SAMPLE_RATE=24000
SARVAM_TTS_OUTPUT_CODEC=pcm
SARVAM_TTS_FALLBACK_SPEAKERS=ritu,neha,kavya,shreya
LLM_PROVIDER_TIMEOUT_SECONDS=6.0

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ── Acoustic Guardian ───────────────────────────────────────────────────────
DISTRESS_THRESHOLD=0.85
WAV2VEC2_MODEL=facebook/wav2vec2-base

# ── PII Scrubber ────────────────────────────────────────────────────────────
PII_NER_MODEL=ai4bharat/IndicNER

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./samvaad_1092.db

# Location resolver. Use "nominatim" for dynamic no-key map search, or
# "disabled" for fully offline demos.
LOCATION_GEOCODER_PROVIDER=nominatim
LOCATION_GEOCODER_TIMEOUT_SECONDS=0.65
LOCATION_GEOCODER_USER_AGENT=Samvaad1092-Hackathon/0.2

# ── Dashboard ───────────────────────────────────────────────────────────────
VITE_WS_URL=ws://localhost:8000/ws/call
